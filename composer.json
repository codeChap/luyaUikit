{
	"name" : "codechap/luya-uikit",
	"description" : "",
	"type" : "luya-extension",
	"keywords" : ["luya", "uikit"],
	"license": "MIT",
	"authors" : [
		{
			"name": "codechap",
			"email": "hello@codechap.com"
		}
	],
	"require-dev" : {
	    "luyadev/luya-testsuite" : "^2.0"
	},
	"autoload" : {
		"psr-4" : {
			"codechap\\uikit\\" : "src/"
		}
	},
	"autoload-dev" : {
       "psr-4" : {
           "codechap\\uikit\\tests\\" : "tests/"
       }
    },
    "config": {
        "fxp-asset": {
            "enabled": false
        }
    },
	"extra" : {
		"luya" : {
			"blocks": [
				"src/uikit"
			],
			"bootstrap": [
				"codechap\\uikit"
			]
		}
	},
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ]
}
